import yaml
import os

class Config:
    def __init__(self, config_file='config.yaml'):
        self.config_file = config_file
        self.load_config()

    def load_config(self):
        with open(self.config_file, 'r') as file:
            cfg = yaml.safe_load(file)
        self.api_key = cfg['openai']['api_key']
        self.prompts_dir = cfg['directories']['prompts']
        self.input_dir = cfg['directories']['input']
        self.output_dir = cfg['directories']['output']
        self.model = cfg['api']['model']
        self.temperature = cfg['api']['temperature']
        self.max_tokens = cfg['api']['max_tokens']
